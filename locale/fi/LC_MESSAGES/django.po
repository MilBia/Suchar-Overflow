msgid "Activation Failed"
msgstr "Aktivoituminen epäonnistui"

#: suchar_overflow/templates/registration/activation_failed.html:26
msgid ""
"The activation link is invalid or has expired. Please try registering again "
"or contact support."
msgstr ""
"Aktivoimislinkki on vanhentunut tai virheellinen. Yritä rekisteröitymistä "
"uudelleen tai ota yhteyttä tukeen."

#: suchar_overflow/templates/registration/activation_failed.html:29
msgid "Sign Up Again"
msgstr "Rekisteröidy uudelleen"

#: suchar_overflow/templates/registration/activation_failed.html:30
#: suchar_overflow/templates/registration/signup_done.html:28
