#: suchar_overflow/templates/registration/login.html:12
#: suchar_overflow/templates/registration/login.html:23
#: suchar_overflow/templates/registration/signup.html:26
msgid "Sign In"
msgstr "സൈൻ ഇൻ ചെയ്യുക"

#: suchar_overflow/templates/registration/login.html:26
