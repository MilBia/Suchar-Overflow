#: suchar_overflow/templates/users/email_notify_old_email.txt:3
#: suchar_overflow/templates/users/email_verify_email.txt:3
#, python-format
msgid "Hello %(username)s!"
msgstr "Γεια σου, %(username)s!"

#: suchar_overflow/templates/registration/activation_email.txt:5
msgid ""
"Welcome to Suchar Overflow - a place where air humidity drops below zero."
msgstr ""
"Καλώς ήρθατε στο Suchar Overflow – έναν τόπο όπου η υγρασία του αέρα πέφτει "
"κάτω από το μηδέν."

#: suchar_overflow/templates/registration/activation_email.txt:6
msgid ""
"To make sure you're not a bot (or a person without a sense of humor), you "
"need to activate your account."
msgstr ""
"Για να βεβαιωθούμε ότι δεν είστε ένα ρομπότ (ή κάποιος χωρίς χιούμορ), "
"πρέπει να ενεργοποιήσετε τον λογαριασμό σας."

#: suchar_overflow/templates/registration/activation_email.txt:8
msgid "Click this link before it dries out:"
msgstr "Κάντε κλικ σε αυτόν τον σύνδεσμο πριν στεγνώσει:"

#: suchar_overflow/templates/registration/activation_email.txt:11
msgid "Remember: Drink plenty of water."
msgstr "Θυμηθείτε: Πίνετε άφθονο νερό."

#: suchar_overflow/templates/registration/activation_email.txt:13
msgid "The Suchar Overflow Team"
msgstr "Η ομάδα Suchar Overflow"

#: suchar_overflow/templates/registration/activation_failed.html:6
